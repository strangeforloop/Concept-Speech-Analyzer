{
  "name": "concept-speech-evaluator-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend API for technical interview concept practice (MVP)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"tsx src/server.ts\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "tsx src/db/seed.ts",
    "export:concepts": "tsx export-concepts.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "nodemon": "^3.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
